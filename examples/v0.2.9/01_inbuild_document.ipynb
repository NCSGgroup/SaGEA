   "cell_type": "code",
   "source": [
    "import sagea\n",
    "\n",
    "print(sagea.SHC.generate.help())"
   ],
   "id": "24d44bccfaf3f3fa",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Available SHC generator methods:\n",
      "\n",
      "  SHC.generate.from_array(cs)\n",
      "      Generate SHC instance with a given 1d- or 2d-array. Equivalent to SHC(...)\n",
      "\n",
      "  SHC.generate.from_trend(shc_trend: \"'SHC'\", dates: 'Sequence[dt.date]', ref_time: 'dt.date | None' = None) -> \"'SHC'\"\n",
      "      Generate SHC time series from a trend SHC (a GIA model, for example).\n",
      "\n",
      "  SHC.generate.normal_from_vcm(vcm: 'np.ndarray', nsample: 'int' = 1, mean: \"'SHC'\" = None) -> \"'SHC'\"\n",
      "      Generate SHC sample(s) from VCM assuming Gaussian distribution.\n",
      "\n",
      "\n",
      "Recommended usage:\n",
      "  SHC.generate.<method_name>(...)\n",
      "\n",
      "Note:\n",
      "  `SHC.generate` is only available from the class, not from an instance.\n"
     ]
    }
   ],
   "execution_count": 5
  },
