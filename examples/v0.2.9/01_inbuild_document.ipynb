    "import sagea\n",
    "\n",
    "print(sagea.SHC.filter.help())"
   ],
   "id": "cd62965e1fccb426",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Available SHC filter methods:\n",
      "\n",
      "  shc.filter.gaussian(radius: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      Gaussian filter, see Wahr et al., 1998, https://doi.org/10.1029/98JB02844\n",
      "\n",
      "  shc.filter.han(radius1: 'int', radius2: 'int', m0: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      A non-isotropic filter designed by Han et al., 2005, https://doi.org/10.1111/j.1365-246X.2005.02756.x\n",
      "\n",
      "  shc.filter.slidewindowSwenson2006(n: 'int', m: 'int', a: 'int', k: 'int', window_length_min: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      An empirical de-correlation filter based on polynomial fitting in a moving window, see Swenson and Wahr, 2006, https://doi.org/10.1029/2005GL025285\n",
      "\n",
      "  shc.filter.fsc(vcm_err, vcm_sig_list, init_alphas, from_degree, scale, *, tol=0.0001, max_iter=100, verbose=True, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      A regularization filter with a hybrid signal VCM, see Liu et al., https://doi.org/under.submission\n",
      "\n",
      "  shc.filter.slidewindowStable(n: 'int', m: 'int', window_length: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      An empirical de-correlation filter based on polynomial fitting in a fixes-length moving window, see Swenson and Wahr, 2006, https://doi.org/10.1029/2005GL025285\n",
      "\n",
      "  shc.filter.pnmm(n: 'int', m: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      An empirical de-correlation filter based on polynomial fitting, see Chambers, 2006, https://doi.org/10.1029/2006GL027296\n",
      "\n",
      "  shc.filter.ddk(ddk_id: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      DDK filter designed by Kusche, 2007, https://doi.org/10.1007/s00190-007-0143-3\n",
      "\n",
      "  shc.filter.regularization(vcm_err, vcm_sig, from_degree=2, alpha=1, *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      A regularization filter with selected the covariance matrix, see Kusche, 2007, https://doi.org/10.1007/s00190-007-0143-3\n",
      "\n",
      "  shc.filter.fan(radius1: 'int', radius2: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      Fan filter designed by Zhang et al., 2009, https://doi.org/10.1029/2009GL039459\n",
      "\n",
      "  shc.filter.slidewindowDuan2009(n: 'int', m: 'int', a: 'int', k: 'int', window_length_min: 'int', gamma: 'float', p: 'int', *, inplace: 'bool' = False) -> \"'SHC'\"\n",
      "      An empirical de-correlation filter based on polynomial fitting in a moving window, see Duan et al., 2009, https://doi.org/10.1007/s00190-009-0327-0\n",
      "\n",
      "\n",
      "Usage:\n",
      "  shc.filter.<method_name>(...)\n",
      "\n",
      "Deprecated old-style usage is still supported temporarily:\n",
      "  shc.filter(\"method_name\", ...)\n",
      "\n",
      "Please check README or documentation for migration details.\n"
     ]
    }
